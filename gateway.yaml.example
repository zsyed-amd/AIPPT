gateway:
  base_url: "https://llm-api.amd.com"
  auth_header: "Ocp-Apim-Subscription-Key"
  auth_value_env: "AMD_LLM_KEY"
  # Mandatory user header (enforced May 2, 2026)
  user_header: "user"
  user_value_env: "AIPPT_USER_NTID"
providers:
  anthropic:
    path: "/Anthropic"
  openai:
    path: "/OpenAI"
  google:
    path: "/VertexAI"

# SharePoint coordinates for the Graph-based Linux render pipeline
# (PPTX -> SharePoint -> ?format=pdf -> pdftoppm -> PNGs).
# Only required on Linux/containerized deployments where PowerPoint COM
# is unavailable. Either set the values inline OR reference an env var
# via the *_env keys (handy for secrets in CI).
sharepoint:
  # Graph site ID, e.g. "contoso.sharepoint.com,<site-guid>,<web-guid>"
  render_site_id: "REPLACE_WITH_SITE_ID"
  # render_site_id_env: "AIPPT_SP_SITE_ID"

  # Graph drive ID for the document library, e.g. "b!xxxxxxxx..."
  render_drive_id: "REPLACE_WITH_DRIVE_ID"
  # render_drive_id_env: "AIPPT_SP_DRIVE_ID"

  # Optional: folder path inside the drive. Defaults to "AIPPT/render-staging".
  # Per-user subfolders (NTID) and per-job filenames (UUID) are appended
  # automatically.
  render_root_path: "AIPPT/render-staging"

# Upload size limit for the web UI. The middleware rejects oversized
# requests before multipart parsing begins; the SPA pre-checks `file.size`
# so the user sees a useful error instead of an opaque HTTP/2 protocol
# error. Default 50. Override per-instance with `aippt serve --max-upload-mb N`.
upload:
  max_size_mb: 50

# Admin tier v1: NTID allowlist. Users on this list get access to admin-
# gated endpoints (DELETE /api/decks/{id}, GET /api/logs) on top of the
# usual Bearer-token requirement. The server trusts the X-AIPPT-NTID
# header for membership checks; audit logs record both the claimed NTID
# and a Bearer-derived identity claim (best-effort, unverified) so
# impersonation attempts are recoverable from /api/logs.
#
# Leave the list empty (or omit the block entirely) to deny everyone --
# useful for fully view-only deployments where no admin actions ever fire.
# Upgrade path to AAD-group-based roles is tracked under the original M2
# PRD.
#
# Matching is case-insensitive; keep entries lowercase and sorted.
admin_ntids:
  - ansgputa
  - edtian
  - egroenke
  - melliott
  - miroy
  - yrajesh
  - zsyed
