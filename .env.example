# Harbor registry and image configuration for AIPPT.
# Copy to .env (gitignored). No robot secrets here -- the publish script uses
# the Harbor CLI and reads short-lived credentials from
# ~/.config/harbor/credentials after `harbor auth login hw-slaiapp-dev`.

HARBOR_REGISTRY=mkmhub.amd.com
HARBOR_PROJECT=hw-slaiapp-dev
IMAGE_NAME=aippt
BUILD_CONTEXT=.
